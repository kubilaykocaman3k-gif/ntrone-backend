# ============================================================
# NTRONE CRM — Ortam Değişkenleri (.env)
# ============================================================
#
# BU DOSYAYI ASLA GIT'E YÜKLEMEYİN!
# .gitignore dosyasına ekleyin.
#
# Değerleri doldurun:
#   MONGO_URI=mongodb+srv://ntrone:3k123456@cluster0.lxzilji.mongodb.net/ntrone-crm?retryWrites=true&w=majority
#   JWT_SECRET → Rastgele uzun bir şifre (en az 32 karakter)
#   PORT       → Sunucunun çalışacağı port (genellikle 5000)
# ============================================================

# Sunucu portu
PORT=5000

# MongoDB Atlas bağlantı adresi
# Atlas'tan aldıktan sonra buraya yapıştırın:
# mongodb+srv://KULLANICI:SIFRE@cluster0.xxxxx.mongodb.net/ntrone-crm
MONGO_URI=mongodb+srv://ntrone:3k123456@cluster0.lxzilji.mongodb.net/ntrone-crm?retryWrites=true&w=majority

# JWT şifreleme anahtarı — kendiniz rastgele bir şey yazın
JWT_SECRET=ntrone_super_gizli_anahtar_degistirin_2025

# Frontend URL (CORS için) — Netlify adresiniz
CLIENT_URL=https://ntrone-crm.netlify.app
